body {
  font-family: Arial;
  background: #f4f6f8;
}

table {
  width: 100%;
  border-collapse: collapse;
}

th {
  background: #2c3e50;
  color: white;
}

.red-row {
  background: #ffe6e6;
}

.yellow-row {
  background: #fff8e1;
}

.approved {
  color: green;
  font-weight: bold;
}

.rejected {
  color: red;
  font-weight: bold;
}